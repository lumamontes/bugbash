# Postgres (Supabase: Project Settings → Database → Connection string → URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional: R2 / S3 for evidence uploads
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
# R2_PUBLIC_URL=

# Optional: Linear integration for bug export
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=

# Optional: Anthropic AI for smart formatting
# ANTHROPIC_API_KEY=
# AI_ENABLED=true
