---
interface Props {
  message: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const { message, ctaLabel, ctaHref } = Astro.props;
---

<div class="flex flex-col items-center justify-center py-16 text-center">
  <p class="text-text-muted text-sm">{message}</p>
  {ctaLabel && ctaHref && (
    <a
      href={ctaHref}
      class="mt-4 inline-flex items-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm font-medium rounded-lg transition-colors"
    >
      {ctaLabel}
    </a>
  )}
</div>
