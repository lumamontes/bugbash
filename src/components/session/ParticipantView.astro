---
import Badge from '@components/ui/Badge.astro';
import Card from '@components/ui/Card.astro';
import SessionTimer from '@components/SessionTimer';
import SessionExecution from '@components/SessionExecution';
import TestScriptExecution from '@components/TestScriptExecution';
import LiveBugFeed from '@components/LiveBugFeed';
import BugListCard from './BugListCard.astro';
import TestResourcesCard from './TestResourcesCard.astro';
import { sessionStatusLabel, formatDateTime } from '@lib/format';

interface Props {
  session: any;
  user: any;
  bugsList: any[];
  credentialsList: any[];
  resourcesList: any[];
  scriptsWithSteps: any[];
  sectionsList: any[];
  bugsCount: number;
  participantsCount: number;
}

const { session, user, bugsList, credentialsList, resourcesList, scriptsWithSteps, sectionsList, bugsCount, participantsCount } = Astro.props;

const isActiveSession = ['kickoff', 'execution', 'wrapup'].includes(session.status);
const isExecutionPhase = session.status === 'execution';
const isWrapupPhase = session.status === 'wrapup';
const isClosed = session.status === 'closed';
const isKickoffPhase = session.status === 'kickoff';
const isDraftOrScheduled = session.status === 'draft' || session.status === 'scheduled';
const hasNewTestingJourney = sectionsList.length > 0;
---

<div class="p-6 md:p-8 max-w-4xl mx-auto">
  <!-- Minimal header -->
  <div class="mb-6">
    <a href="/sessions" class="text-text-muted hover:text-text-primary text-sm">&larr; Sessões</a>
    <h1 class="text-2xl font-bold text-text-primary mt-3">{session.title}</h1>
    <div class="flex items-center gap-3 mt-2">
      <Badge variant="session-status" value={session.status}>{sessionStatusLabel(session.status)}</Badge>
    </div>
    {session.description && <p class="text-text-secondary mt-3 whitespace-pre-line">{session.description}</p>}
  </div>

  <!-- Timer (always visible during active phases) -->
  {isActiveSession && (
    <div class="mb-6">
      <SessionTimer
        status={session.status}
        startedAt={session.startedAt?.toISOString() ?? null}
        kickoffDuration={session.kickoffDuration ?? 15}
        executionDuration={session.executionDuration ?? 60}
        wrapupDuration={session.wrapupDuration ?? 15}
        client:load
      />
    </div>
  )}

  <!-- DRAFT / SCHEDULED: Simple waiting message -->
  {isDraftOrScheduled && (
    <Card>
      <div class="py-12 text-center">
        <div class="text-4xl mb-4">&#9203;</div>
        <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão ainda não iniciada</h2>
        <p class="text-text-secondary text-sm max-w-md mx-auto">
          Aguarde o facilitador iniciar a sessão. Você será notificado quando começar.
        </p>
        {session.scheduledAt && (
          <p class="text-text-muted text-sm mt-4">Agendada para {formatDateTime(session.scheduledAt)}</p>
        )}
      </div>
    </Card>
  )}

  <!-- KICKOFF: Briefing view -->
  {isKickoffPhase && (
    <div class="space-y-6">
      <Card>
        <div class="py-8 text-center">
          <div class="text-4xl mb-4">&#128227;</div>
          <h2 class="text-lg font-semibold text-text-primary mb-2">Kickoff em andamento</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Acompanhe as orientações do facilitador. A fase de execução vai começar em breve.
          </p>
        </div>
      </Card>

      {credentialsList.length > 0 && (
        <Card>
          <h2 class="text-sm font-semibold text-text-primary mb-3">Credenciais de Teste</h2>
          <p class="text-xs text-text-muted mb-4">Reserve uma credencial para usar durante os testes.</p>
          <div class="space-y-2">
            {credentialsList.map(c => (
              <div class="flex items-center justify-between p-3 rounded-lg bg-surface-2">
                <div class="flex items-center gap-4">
                  <span class="text-sm font-medium text-text-primary">{c.profileType}</span>
                  <span class="text-xs text-text-muted">{c.environment || ''}</span>
                </div>
              </div>
            ))}
          </div>
        </Card>
      )}

      {resourcesList.length > 0 && (
        <TestResourcesCard sessionId={session.id} resources={resourcesList} isFacilitator={false} />
      )}
    </div>
  )}

  <!-- EXECUTION: The participant's main workspace -->
  {isExecutionPhase && (
    <div class="space-y-6">
      <a
        href={`/sessions/${session.id}/bugs/new`}
        class="flex items-center justify-center gap-3 w-full py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-2xl transition-colors text-base"
      >
        Reportar Bug
      </a>

      {hasNewTestingJourney ? (
        <Card>
          <h2 class="text-sm font-semibold text-text-primary mb-4">Roteiro de Testes</h2>
          <SessionExecution sessionId={session.id} userId={user.id} sections={sectionsList} client:load />
        </Card>
      ) : scriptsWithSteps.length > 0 ? (
        <Card>
          <h2 class="text-sm font-semibold text-text-primary mb-4">Scripts de Teste</h2>
          <TestScriptExecution sessionId={session.id} scripts={scriptsWithSteps} client:load />
        </Card>
      ) : null}

      {credentialsList.length > 0 && (
        <Card>
          <h2 class="text-sm font-semibold text-text-primary mb-3">Suas Credenciais</h2>
          <div class="space-y-2">
            {credentialsList.map(c => (
              <div class="flex items-center justify-between p-3 rounded-lg bg-surface-2">
                <div>
                  <span class="text-sm font-medium text-text-primary">{c.profileType}</span>
                  {c.claimedBy === user.id && (
                    <div class="text-xs text-text-muted mt-0.5 font-mono">{c.username} / {c.password}</div>
                  )}
                </div>
                <div></div>
              </div>
            ))}
          </div>
        </Card>
      )}

      {resourcesList.length > 0 && (
        <TestResourcesCard sessionId={session.id} resources={resourcesList} isFacilitator={false} />
      )}

      <Card>
        <LiveBugFeed sessionId={session.id} initialBugs={bugsList} client:load />
      </Card>
    </div>
  )}

  <!-- WRAPUP: Read-only summary -->
  {isWrapupPhase && (
    <div class="space-y-6">
      <Card>
        <div class="py-8 text-center">
          <div class="text-4xl mb-4">&#9989;</div>
          <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão encerrada</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Obrigado pela participação! Os bugs reportados estão sendo revisados.
          </p>
        </div>
      </Card>

      {bugsList.length > 0 && <BugListCard sessionId={session.id} bugs={bugsList} />}
    </div>
  )}

  <!-- CLOSED: Final summary -->
  {isClosed && (
    <div class="space-y-6">
      <Card>
        <div class="py-8 text-center">
          <div class="text-4xl mb-4">&#127942;</div>
          <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão finalizada</h2>
          <p class="text-text-secondary text-sm max-w-md mx-auto">
            Esta sessão foi concluída. Confira suas conquistas na aba Conquistas.
          </p>
          <div class="flex items-center justify-center gap-6 mt-6">
            <div>
              <p class="text-2xl font-bold text-text-primary">{bugsCount}</p>
              <p class="text-xs text-text-muted">Bugs reportados</p>
            </div>
            <div>
              <p class="text-2xl font-bold text-text-primary">{participantsCount}</p>
              <p class="text-xs text-text-muted">Participantes</p>
            </div>
          </div>
        </div>
      </Card>

      {bugsList.length > 0 && <BugListCard sessionId={session.id} bugs={bugsList} />}
    </div>
  )}
</div>
