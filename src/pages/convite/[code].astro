---
import Layout from '../../layouts/Layout.astro';
import { verifyInvite } from '@lib/auth/invites';
import { db } from '@db/index';
import { users, organizations } from '@db/schema';
import { eq } from 'drizzle-orm';

const { code } = Astro.params;
const invite = code ? await verifyInvite(code) : null;

if (!invite) {
  return Astro.redirect('/entrar?error=invite_invalid');
}

// Get creator's org to show squads
const creator = (await db.select().from(users).where(eq(users.id, invite.createdBy)))[0];
const orgId = creator?.orgId;
const org = orgId ? (await db.select().from(organizations).where(eq(organizations.id, orgId)))[0] : null;

const error = Astro.url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  missing_fields: 'Por favor, preencha todos os campos.',
  email_exists: 'Este email já está cadastrado. Faça login.',
  invite_invalid: 'Convite inválido ou expirado.',
  domain_not_allowed: 'Domínio de email não permitido.',
};

const errorMessage = error ? errorMessages[error] ?? 'Erro desconhecido.' : null;

const roleLabel: Record<string, string> = {
  admin: 'Admin',
  facilitator: 'Facilitador',
  participant: 'Participante',
};
---

<Layout title="Entrar via Convite — Bug Bash">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="w-full max-w-sm">
      <div class="text-center mb-8">
        <img src="https://cdn.arcotech.io/iris-ds/brand/arcotech/icon.svg" alt="Arcotech" width="40" height="40" class="mx-auto mb-3" />
        <h1 class="text-2xl font-bold text-text-primary">Bug Bash</h1>
        <p class="text-sm text-text-secondary mt-2">
          Você foi convidado para {org?.name ?? 'a organização'}
        </p>
        <p class="text-xs text-text-muted mt-1">
          Papel: <span class="font-medium text-primary-400">{roleLabel[invite.role] ?? invite.role}</span>
        </p>
      </div>

      <form method="POST" action="/api/auth/join" class="bg-surface-1 rounded-2xl border border-surface-3 p-6 space-y-4">
        <input type="hidden" name="code" value={code} />

        {errorMessage && (
          <div class="bg-red-500/10 border border-red-500/20 text-red-400 text-sm rounded-lg px-4 py-3">
            {errorMessage}
          </div>
        )}

        <div>
          <label for="name" class="block text-sm font-medium text-text-secondary mb-1.5">Nome completo</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            autocomplete="name"
            class="w-full bg-surface-2 border border-surface-3 rounded-lg px-3 py-2 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            placeholder="Seu nome"
          />
        </div>

        <div>
          <label for="email" class="block text-sm font-medium text-text-secondary mb-1.5">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            autocomplete="email"
            class="w-full bg-surface-2 border border-surface-3 rounded-lg px-3 py-2 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
            placeholder="seu@email.com"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-primary-600 hover:bg-primary-700 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-colors focus:outline-none focus:ring-2 focus:ring-primary-500 focus:ring-offset-2 focus:ring-offset-surface-1"
        >
          Criar conta e entrar
        </button>
      </form>

      <p class="text-center mt-4 text-sm text-text-muted">
        Já tem conta? <a href="/entrar" class="text-primary-400 hover:text-primary-300">Faça login</a>
      </p>
    </div>
  </div>
</Layout>
