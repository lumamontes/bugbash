---
import AppLayout from '../../../layouts/app-layout.astro';
import ScriptBuilder from '../../../components/ScriptBuilder';
import { db } from '@db/index';
import { sessions, testScripts, testSections, testScenarios } from '@db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user;
if (!user) return Astro.redirect('/login');

const { id } = Astro.params;
const session = (await db.select().from(sessions).where(eq(sessions.id, id!)))[0];
if (!session || session.orgId !== user.orgId) return Astro.redirect('/');

// Get or create the script for this session
let script = (await db.select().from(testScripts).where(eq(testScripts.sessionId, id!)))[0];
if (!script) {
  const scriptId = crypto.randomUUID();
  await db.insert(testScripts).values({
    id: scriptId,
    sessionId: id!,
    title: session.title + ' - Roteiro',
    orderIndex: 0,
    createdAt: new Date(),
    updatedAt: new Date(),
  });
  script = (await db.select().from(testScripts).where(eq(testScripts.id, scriptId)))[0]!;
}

// Load sections with scenarios
const sectionsList: any[] = [];
const dbSections = await db.select().from(testSections).where(eq(testSections.scriptId, script.id)).orderBy(testSections.sortOrder);
for (const section of dbSections) {
  const scenarios = await db.select().from(testScenarios).where(eq(testScenarios.sectionId, section.id)).orderBy(testScenarios.sortOrder);
  sectionsList.push({ ...section, scenarios });
}
---
<AppLayout title={`Roteiro — ${session.title}`}>
  <div class="max-w-5xl mx-auto p-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-zinc-100">{script.title}</h1>
        <p class="text-zinc-400 mt-1">Gerencie seções e cenários do roteiro de teste</p>
      </div>
      <a href={`/sessions/${id}`} class="text-sm text-zinc-400 hover:text-zinc-200 transition-colors">
        &larr; Voltar à sessão
      </a>
    </div>
    <ScriptBuilder
      client:load
      sessionId={id!}
      scriptId={script.id}
      scriptTitle={script.title}
      initialSections={sectionsList}
    />
  </div>
</AppLayout>
