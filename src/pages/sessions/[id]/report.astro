---
import AppLayout from '../../../layouts/app-layout.astro';
import Card from '@components/ui/Card.astro';
import Badge from '@components/ui/Badge.astro';
import StatsGrid from '@components/ui/StatsGrid.astro';
import ReportCharts from '@components/ReportCharts';
import { db } from '@db/index';
import { testScripts, testSteps, testStepResults, userBadges, badgeDefinitions, users } from '@db/schema';
import { eq, count } from 'drizzle-orm';
import { bugSeverityLabel, bugStatusLabel, formatDate } from '@lib/format';
import { getSessionWithCreator, getSessionCounts, getBugsListWithType } from '@lib/services/sessions';

const user = Astro.locals.user!;
const { id } = Astro.params;

const session = await getSessionWithCreator(id!);
if (!session || session.orgId !== user.orgId) return Astro.redirect('/sessions');

const [{ participantsCount }, allBugs] = await Promise.all([
  getSessionCounts(id!),
  getBugsListWithType(id!),
]);

const totalBugs = allBugs.length;

// Severity counts
const severityCounts: Record<string, number> = { blocker: 0, major: 0, minor: 0, enhancement: 0 };
allBugs.forEach(b => { severityCounts[b.severity] = (severityCounts[b.severity] || 0) + 1; });

const severityData = [
  { name: 'Bloqueante', value: severityCounts.blocker, color: '#ef4444' },
  { name: 'Grave', value: severityCounts.major, color: '#f97316' },
  { name: 'Menor', value: severityCounts.minor, color: '#eab308' },
  { name: 'Melhoria', value: severityCounts.enhancement, color: '#22c55e' },
].filter(d => d.value > 0);

// Status counts
const statusCounts: Record<string, number> = {};
allBugs.forEach(b => { statusCounts[b.status] = (statusCounts[b.status] || 0) + 1; });

const statusColors: Record<string, string> = {
  open: '#ef4444',
  confirmed: '#f97316',
  fixed: '#22c55e',
  wontfix: '#64748b',
  duplicate: '#94a3b8',
};

const statusData = Object.entries(statusCounts).map(([status, cnt]) => ({
  name: bugStatusLabel(status),
  value: cnt,
  color: statusColors[status] || '#6366f1',
}));

// Reporter counts
const reporterCounts: Record<string, number> = {};
allBugs.forEach(b => { reporterCounts[b.reporterName] = (reporterCounts[b.reporterName] || 0) + 1; });
const reporterData = Object.entries(reporterCounts)
  .map(([name, cnt]) => ({ name, count: cnt }))
  .sort((a, b) => b.count - a.count);

// Test coverage
const totalSteps = (await db
  .select({ count: count() })
  .from(testSteps)
  .innerJoin(testScripts, eq(testSteps.scriptId, testScripts.id))
  .where(eq(testScripts.sessionId, id!))
)[0]!.count;

const completedSteps = await db
  .select({ stepId: testStepResults.stepId })
  .from(testStepResults)
  .where(eq(testStepResults.sessionId, id!));
const uniqueCompletedSteps = new Set(completedSteps.map(r => r.stepId)).size;
const coveragePercent = totalSteps > 0 ? Math.round((uniqueCompletedSteps / totalSteps) * 100) : 0;

// Session duration
let durationStr = '—';
if (session.startedAt && session.endedAt) {
  const diffMin = Math.round((session.endedAt.getTime() - session.startedAt.getTime()) / 60000);
  if (diffMin < 60) {
    durationStr = `${diffMin} min`;
  } else {
    durationStr = `${Math.floor(diffMin / 60)}h ${diffMin % 60}min`;
  }
}

// Badges earned in this session
const sessionBadges = await db
  .select({
    userName: users.name,
    badgeName: badgeDefinitions.name,
    badgeIcon: badgeDefinitions.icon,
    badgeTier: badgeDefinitions.tier,
    earnedAt: userBadges.earnedAt,
  })
  .from(userBadges)
  .innerJoin(users, eq(userBadges.userId, users.id))
  .innerJoin(badgeDefinitions, eq(userBadges.badgeId, badgeDefinitions.id))
  .where(eq(userBadges.sessionId, id!))
  .orderBy(userBadges.earnedAt);
---

<AppLayout title={`Relatório — ${session.title}`}>
  <div class="p-8">
    <!-- Header -->
    <div class="flex items-start justify-between mb-8">
      <div>
        <div class="flex items-center gap-3 mb-2">
          <a href={`/sessions/${id}`} class="text-text-muted hover:text-text-primary text-sm">&larr; Sessão</a>
        </div>
        <h1 class="text-2xl font-bold text-text-primary">Relatório da Sessão</h1>
        <p class="text-text-secondary mt-1">{session.title}</p>
      </div>
      <a
        href={`/api/sessions/${id}/report/markdown`}
        target="_blank"
        class="inline-flex items-center px-4 py-2 bg-surface-2 border border-surface-3 hover:bg-surface-3 text-text-primary text-sm font-medium rounded-lg transition-colors"
      >
        Exportar Markdown
      </a>
    </div>

    <!-- Summary Stats -->
    <StatsGrid
      stats={[
        { label: 'Total de Bugs', value: totalBugs },
        { label: 'Participantes', value: participantsCount },
        { label: 'Cobertura', value: `${coveragePercent}%` },
        { label: 'Duração', value: durationStr },
      ]}
      class="mb-8"
    />

    <!-- Charts -->
    <div class="mb-8">
      <ReportCharts
        severityData={severityData}
        reporterData={reporterData}
        statusData={statusData}
        client:load
      />
    </div>

    <!-- Conquistas da Sessão -->
    {sessionBadges.length > 0 && (
      <Card class="mb-8">
        <h2 class="text-lg font-semibold text-text-primary mb-4">Conquistas da Sessão ({sessionBadges.length})</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
          {sessionBadges.map(b => (
            <div class="flex items-center gap-3 p-3 rounded-lg bg-surface-2">
              <span class="text-2xl">{b.badgeIcon}</span>
              <div>
                <p class="text-sm font-medium text-text-primary">{b.badgeName}</p>
                <p class="text-xs text-text-muted">{b.userName}</p>
              </div>
            </div>
          ))}
        </div>
      </Card>
    )}

    <!-- Full Bug List -->
    <Card>
      <h2 class="text-lg font-semibold text-text-primary mb-4">Todos os Bugs ({totalBugs})</h2>
      {allBugs.length === 0 ? (
        <p class="text-text-muted text-sm py-4 text-center">Nenhum bug reportado.</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-surface-3">
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Título</th>
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Severidade</th>
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Status</th>
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Tipo</th>
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Reporter</th>
                <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Data</th>
              </tr>
            </thead>
            <tbody>
              {allBugs.map(b => (
                <tr class="border-b border-surface-3 last:border-0 hover:bg-surface-2 transition-colors">
                  <td class="px-3 py-2">
                    <a href={`/sessions/${id}/bugs/${b.id}`} class="text-text-primary hover:text-primary-400 font-medium">{b.title}</a>
                  </td>
                  <td class="px-3 py-2"><Badge variant="bug-severity" value={b.severity}>{bugSeverityLabel(b.severity)}</Badge></td>
                  <td class="px-3 py-2"><Badge variant="bug-status" value={b.status}>{bugStatusLabel(b.status)}</Badge></td>
                  <td class="px-3 py-2 text-text-secondary text-xs">{b.type === 'bug' ? 'Bug' : b.type === 'improvement' ? 'Melhoria' : 'Insight UX'}</td>
                  <td class="px-3 py-2 text-text-secondary">{b.reporterName}</td>
                  <td class="px-3 py-2 text-text-secondary">{formatDate(b.createdAt)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </Card>
  </div>
</AppLayout>
