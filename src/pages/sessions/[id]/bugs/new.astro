---
import AppLayout from '../../../../layouts/app-layout.astro';
import PageHeader from '@components/ui/PageHeader.astro';
import Card from '@components/ui/Card.astro';
import BugReportForm from '@components/BugReportForm';
import { db } from '@db/index';
import { sessions, testScripts, testSteps, testScenarios, testSections } from '@db/schema';
import { eq } from 'drizzle-orm';

const user = Astro.locals.user!;
const { id } = Astro.params;

const session = db.select().from(sessions).where(eq(sessions.id, id!)).get();
if (!session || session.orgId !== user.orgId) {
  return Astro.redirect('/sessions');
}

// Get test steps for optional linking (legacy)
const scripts = db.select({ id: testScripts.id, title: testScripts.title }).from(testScripts).where(eq(testScripts.sessionId, id!)).all();
const steps = scripts.flatMap(script => {
  const scriptSteps = db.select({ id: testSteps.id, instruction: testSteps.instruction }).from(testSteps).where(eq(testSteps.scriptId, script.id)).all();
  return scriptSteps.map(s => ({ ...s, scriptTitle: script.title }));
});

// Check for scenario context from query params
const scenarioId = Astro.url.searchParams.get('scenarioId');
const sectionId = Astro.url.searchParams.get('sectionId');
const mode = Astro.url.searchParams.get('mode') as 'guided' | 'freeform' | null;
const defaultType = Astro.url.searchParams.get('type') || undefined;

let scenarioContext = null;
if (scenarioId && sectionId) {
  const scenario = db.select().from(testScenarios).where(eq(testScenarios.id, scenarioId)).get();
  const section = db.select().from(testSections).where(eq(testSections.id, sectionId)).get();
  if (scenario && section) {
    scenarioContext = {
      scenarioId: scenario.id,
      scenarioTitle: scenario.title,
      sectionId: section.id,
      sectionTitle: section.title,
      precondition: scenario.precondition || undefined,
      stepsToExecute: scenario.stepsToExecute || undefined,
      expectedResult: scenario.expectedResult || undefined,
    };
  }
}

const reportMode = scenarioContext ? 'guided' : (mode || 'freeform');
const isFacilitator = user.role === 'admin' || user.role === 'facilitator';
---

<AppLayout title={`Reportar Bug — ${session.title}`}>
  <div class="p-8 max-w-2xl">
    <div class="mb-6">
      <a href={`/sessions/${id}`} class="text-text-muted hover:text-text-primary text-sm">&larr; Voltar para sessão</a>
    </div>
    <PageHeader title="Reportar Bug" description={`Sessão: ${session.title}`} />

    <Card>
      <BugReportForm
        sessionId={id!}
        testSteps={steps}
        reportMode={reportMode}
        scenarioContext={scenarioContext}
        defaultType={defaultType}
        showQuality={isFacilitator}
        client:load
      />
    </Card>
  </div>
</AppLayout>
