---
import AppLayout from '../../layouts/app-layout.astro';
import StoreInit from '@components/StoreInit';
import StatusWatcher from '@components/StatusWatcher';
import BadgeToast from '@components/BadgeToast';
import ParticipantView from '@components/session/ParticipantView.astro';
import FacilitatorView from '@components/session/FacilitatorView.astro';
import {
  getSessionWithCreator,
  getSessionCounts,
  getParticipants,
  getCredentials,
  getBugsList,
  getScriptsWithSteps,
  getSectionsWithScenarios,
  getTestResources,
  addParticipant,
} from '@lib/services/sessions';

const user = Astro.locals.user!;
const { id } = Astro.params;

const session = await getSessionWithCreator(id!);
if (!session) return Astro.redirect('/sessions');

const isFacilitator = session.createdBy === user.id || user.role === 'admin' || user.role === 'facilitator';

// Auto-join: add user as participant when they visit an active session
const isActive = ['kickoff', 'execution', 'wrapup'].includes(session.status);
if (isActive) {
  await addParticipant(id!, user.id);
}

const [counts, participantsList, credentialsList, bugsList, scriptsWithSteps, sectionsList, resourcesList] = await Promise.all([
  getSessionCounts(id!),
  getParticipants(id!),
  getCredentials(id!),
  getBugsList(id!),
  getScriptsWithSteps(id!),
  getSectionsWithScenarios(id!),
  getTestResources(id!),
]);

const storeSession = {
  id: session.id,
  title: session.title,
  description: session.description,
  status: session.status,
  startedAt: session.startedAt?.toISOString() ?? null,
  kickoffDuration: session.kickoffDuration ?? 15,
  executionDuration: session.executionDuration ?? 60,
  wrapupDuration: session.wrapupDuration ?? 15,
};

const storeUser = {
  id: user.id,
  role: user.role,
  isFacilitator,
};
---

<AppLayout title={`${session.title} — Bug Bash`}>
  <StoreInit session={storeSession} user={storeUser} initialBugs={bugsList} client:load />
  <StatusWatcher client:load />

  {!isFacilitator ? (
    <ParticipantView
      session={session}
      credentialsList={credentialsList}
      resourcesList={resourcesList}
      scriptsWithSteps={scriptsWithSteps}
      sectionsList={sectionsList}
      bugsCount={counts.bugsCount}
      participantsCount={counts.participantsCount}
    />
  ) : (
    <FacilitatorView
      session={session}
      bugsList={bugsList}
      credentialsList={credentialsList}
      resourcesList={resourcesList}
      participantsList={participantsList}
      scriptsWithSteps={scriptsWithSteps}
      sectionsList={sectionsList}
      counts={counts}
    />
  )}

  {(session.status === 'execution' || session.status === 'kickoff') && (
    <BadgeToast client:load />
  )}
</AppLayout>
