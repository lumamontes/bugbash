---
import AppLayout from '../../layouts/app-layout.astro';
import Badge from '@components/ui/Badge.astro';
import Card from '@components/ui/Card.astro';
import SessionStatusControl from '@components/SessionStatusControl';
import AddParticipant from '@components/AddParticipant';
import TestScriptExecution from '@components/TestScriptExecution';
import SessionExecution from '@components/SessionExecution';
import CoverageMatrix from '@components/CoverageMatrix';
import SessionTimer from '@components/SessionTimer';
import LiveBugFeed from '@components/LiveBugFeed';
import TriageTable from '@components/TriageTable';
import BadgeToast from '@components/BadgeToast';
import { db } from '@db/index';
import { sessions, sessionParticipants, testScripts, testSteps, testSections, testScenarios, testCredentials, bugs, users } from '@db/schema';
import { eq, count, sql, desc } from 'drizzle-orm';
import { sessionStatusLabel, bugSeverityLabel, bugStatusLabel, formatDate, formatDateTime } from '@lib/format';

const user = Astro.locals.user!;
const { id } = Astro.params;

// Fetch session with creator
const session = db
  .select({
    id: sessions.id,
    title: sessions.title,
    description: sessions.description,
    status: sessions.status,
    orgId: sessions.orgId,
    createdBy: sessions.createdBy,
    scheduledAt: sessions.scheduledAt,
    startedAt: sessions.startedAt,
    endedAt: sessions.endedAt,
    kickoffDuration: sessions.kickoffDuration,
    executionDuration: sessions.executionDuration,
    wrapupDuration: sessions.wrapupDuration,
    createdAt: sessions.createdAt,
    creatorName: users.name,
  })
  .from(sessions)
  .innerJoin(users, eq(sessions.createdBy, users.id))
  .where(eq(sessions.id, id!))
  .get();

if (!session || session.orgId !== user.orgId) {
  return Astro.redirect('/sessions');
}

// Counts
const participantsCount = db.select({ count: count() }).from(sessionParticipants).where(eq(sessionParticipants.sessionId, id!)).get()!.count;
const bugsCount = db.select({ count: count() }).from(bugs).where(eq(bugs.sessionId, id!)).get()!.count;
const scriptsCount = db.select({ count: count() }).from(testScripts).where(eq(testScripts.sessionId, id!)).get()!.count;
const credentialsCount = db.select({ count: count() }).from(testCredentials).where(eq(testCredentials.sessionId, id!)).get()!.count;

// Participants list
const participantsList = db
  .select({
    id: sessionParticipants.id,
    userId: users.id,
    name: users.name,
    email: users.email,
    squadId: users.squadId,
  })
  .from(sessionParticipants)
  .innerJoin(users, eq(sessionParticipants.userId, users.id))
  .where(eq(sessionParticipants.sessionId, id!))
  .all();

// Scripts with steps (full data for interactive execution)
const scriptsList = db
  .select({
    id: testScripts.id,
    title: testScripts.title,
    description: testScripts.description,
    orderIndex: testScripts.orderIndex,
  })
  .from(testScripts)
  .where(eq(testScripts.sessionId, id!))
  .orderBy(testScripts.orderIndex)
  .all();

const scriptsWithSteps = scriptsList.map(script => {
  const steps = db
    .select({
      id: testSteps.id,
      instruction: testSteps.instruction,
      expectedResult: testSteps.expectedResult,
      orderIndex: testSteps.orderIndex,
    })
    .from(testSteps)
    .where(eq(testSteps.scriptId, script.id))
    .orderBy(testSteps.orderIndex)
    .all();
  return { ...script, steps };
});

// Load sections with scenarios (new testing journey)
const sectionsList: any[] = [];
for (const script of scriptsList) {
  const dbSections = db.select().from(testSections).where(eq(testSections.scriptId, script.id)).orderBy(testSections.sortOrder).all();
  for (const section of dbSections) {
    const scenarios = db.select().from(testScenarios).where(eq(testScenarios.sectionId, section.id)).orderBy(testScenarios.sortOrder).all();
    sectionsList.push({ ...section, scriptTitle: script.title, scenarios });
  }
}
const hasNewTestingJourney = sectionsList.length > 0;
const isFacilitator = session.createdBy === user.id || user.role === 'admin' || user.role === 'facilitator';

// Credentials
const credentialsList = db
  .select({
    id: testCredentials.id,
    profileType: testCredentials.profileType,
    username: testCredentials.username,
    password: testCredentials.password,
    environment: testCredentials.environment,
    claimedBy: testCredentials.claimedBy,
    claimedByName: sql<string | null>`(SELECT name FROM users WHERE id = ${testCredentials.claimedBy})`,
  })
  .from(testCredentials)
  .where(eq(testCredentials.sessionId, id!))
  .all();

// Bugs
const bugsList = db
  .select({
    id: bugs.id,
    title: bugs.title,
    severity: bugs.severity,
    status: bugs.status,
    reportedVia: bugs.reportedVia,
    createdAt: bugs.createdAt,
    reporterName: users.name,
  })
  .from(bugs)
  .innerJoin(users, eq(bugs.reportedBy, users.id))
  .where(eq(bugs.sessionId, id!))
  .orderBy(desc(bugs.createdAt))
  .all();

const isActiveSession = ['kickoff', 'execution', 'wrapup'].includes(session.status);
const isExecutionPhase = session.status === 'execution';
const isWrapupPhase = session.status === 'wrapup';
const isClosed = session.status === 'closed';
const isParticipant = !isFacilitator;
const isKickoffPhase = session.status === 'kickoff';
const isDraftOrScheduled = session.status === 'draft' || session.status === 'scheduled';
---

<AppLayout title={`${session.title} — Bug Bash`}>
  {isParticipant ? (
    <!-- ==================== PARTICIPANT VIEW ==================== -->
    <div class="p-6 md:p-8 max-w-4xl mx-auto">
      <!-- Minimal header -->
      <div class="mb-6">
        <a href="/sessions" class="text-text-muted hover:text-text-primary text-sm">&larr; Sessões</a>
        <h1 class="text-2xl font-bold text-text-primary mt-3">{session.title}</h1>
        <div class="flex items-center gap-3 mt-2">
          <Badge variant="session-status" value={session.status}>{sessionStatusLabel(session.status)}</Badge>
        </div>
        {session.description && <p class="text-text-secondary mt-3 whitespace-pre-line">{session.description}</p>}
      </div>

      <!-- Timer (always visible during active phases) -->
      {isActiveSession && (
        <div class="mb-6">
          <SessionTimer
            status={session.status}
            startedAt={session.startedAt?.toISOString() ?? null}
            kickoffDuration={session.kickoffDuration ?? 15}
            executionDuration={session.executionDuration ?? 60}
            wrapupDuration={session.wrapupDuration ?? 15}
            client:load
          />
        </div>
      )}

      <!-- DRAFT / SCHEDULED: Simple waiting message -->
      {isDraftOrScheduled && (
        <Card>
          <div class="py-12 text-center">
            <div class="text-4xl mb-4">&#9203;</div>
            <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão ainda não iniciada</h2>
            <p class="text-text-secondary text-sm max-w-md mx-auto">
              Aguarde o facilitador iniciar a sessão. Você será notificado quando começar.
            </p>
            {session.scheduledAt && (
              <p class="text-text-muted text-sm mt-4">Agendada para {formatDateTime(session.scheduledAt)}</p>
            )}
          </div>
        </Card>
      )}

      <!-- KICKOFF: Briefing view — credentials to claim, that's it -->
      {isKickoffPhase && (
        <div class="space-y-6">
          <Card>
            <div class="py-8 text-center">
              <div class="text-4xl mb-4">&#128227;</div>
              <h2 class="text-lg font-semibold text-text-primary mb-2">Kickoff em andamento</h2>
              <p class="text-text-secondary text-sm max-w-md mx-auto">
                Acompanhe as orientações do facilitador. A fase de execução vai começar em breve.
              </p>
            </div>
          </Card>

          <!-- Credentials to claim during kickoff -->
          {credentialsList.length > 0 && (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-3">Credenciais de Teste</h2>
              <p class="text-xs text-text-muted mb-4">Reserve uma credencial para usar durante os testes.</p>
              <div class="space-y-2">
                {credentialsList.map(c => (
                  <div class="flex items-center justify-between p-3 rounded-lg bg-surface-2">
                    <div class="flex items-center gap-4">
                      <span class="text-sm font-medium text-text-primary">{c.profileType}</span>
                      <span class="text-xs text-text-muted">{c.environment || ''}</span>
                    </div>
                    <div class="flex items-center gap-3">
                      {c.claimedBy === user.id ? (
                        <Fragment>
                          <span class="text-xs text-primary-400">Reservado por você</span>
                          <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                            <input type="hidden" name="_method" value="DELETE" />
                            <button type="submit" class="text-xs text-text-muted hover:text-severity-major transition-colors">Liberar</button>
                          </form>
                        </Fragment>
                      ) : c.claimedBy ? (
                        <span class="text-xs text-text-muted">Reservado por {c.claimedByName}</span>
                      ) : (
                        <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                          <button type="submit" class="inline-flex items-center px-3 py-1 bg-primary-600 hover:bg-primary-700 text-white text-xs font-medium rounded-lg transition-colors">
                            Reservar
                          </button>
                        </form>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </Card>
          )}
        </div>
      )}

      <!-- EXECUTION: The participant's main workspace -->
      {isExecutionPhase && (
        <div class="space-y-6">
          <!-- Big CTA to report a bug -->
          <a
            href={`/sessions/${session.id}/bugs/new`}
            class="flex items-center justify-center gap-3 w-full py-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-colors text-base"
          >
            Reportar Bug
          </a>

          <!-- Test scripts / execution journey -->
          {hasNewTestingJourney ? (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-4">Roteiro de Testes</h2>
              <SessionExecution sessionId={session.id} userId={user.id} sections={sectionsList} client:load />
            </Card>
          ) : scriptsWithSteps.length > 0 ? (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-4">Scripts de Teste</h2>
              <TestScriptExecution sessionId={session.id} scripts={scriptsWithSteps} client:load />
            </Card>
          ) : null}

          <!-- Credentials (compact, claim only) -->
          {credentialsList.length > 0 && (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-3">Suas Credenciais</h2>
              <div class="space-y-2">
                {credentialsList.map(c => (
                  <div class="flex items-center justify-between p-3 rounded-lg bg-surface-2">
                    <div>
                      <span class="text-sm font-medium text-text-primary">{c.profileType}</span>
                      {c.claimedBy === user.id && (
                        <div class="text-xs text-text-muted mt-0.5 font-mono">{c.username} / {c.password}</div>
                      )}
                    </div>
                    <div>
                      {c.claimedBy === user.id ? (
                        <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                          <input type="hidden" name="_method" value="DELETE" />
                          <button type="submit" class="text-xs text-text-muted hover:text-severity-major transition-colors">Liberar</button>
                        </form>
                      ) : c.claimedBy ? (
                        <span class="text-xs text-text-muted">Em uso</span>
                      ) : (
                        <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                          <button type="submit" class="text-xs text-primary-400 hover:text-primary-300">Reservar</button>
                        </form>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </Card>
          )}

          <!-- Live bug feed -->
          <Card>
            <LiveBugFeed sessionId={session.id} initialBugs={bugsList} client:load />
          </Card>
        </div>
      )}

      <!-- WRAPUP: Read-only summary of reported bugs -->
      {isWrapupPhase && (
        <div class="space-y-6">
          <Card>
            <div class="py-8 text-center">
              <div class="text-4xl mb-4">&#9989;</div>
              <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão encerrada</h2>
              <p class="text-text-secondary text-sm max-w-md mx-auto">
                Obrigado pela participação! Os bugs reportados estão sendo revisados.
              </p>
            </div>
          </Card>

          {bugsList.length > 0 && (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-3">Bugs reportados ({bugsList.length})</h2>
              <div class="space-y-2">
                {bugsList.map(b => (
                  <a href={`/sessions/${session.id}/bugs/${b.id}`} class="flex items-center justify-between p-3 rounded-lg bg-surface-2 hover:bg-surface-3 transition-colors">
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-text-primary truncate">{b.title}</p>
                      <p class="text-xs text-text-muted mt-0.5">{b.reporterName}</p>
                    </div>
                    <div class="flex items-center gap-2 ml-3">
                      <Badge variant="bug-severity" value={b.severity}>{bugSeverityLabel(b.severity)}</Badge>
                      <Badge variant="bug-status" value={b.status}>{bugStatusLabel(b.status)}</Badge>
                    </div>
                  </a>
                ))}
              </div>
            </Card>
          )}
        </div>
      )}

      <!-- CLOSED: Final summary -->
      {isClosed && (
        <div class="space-y-6">
          <Card>
            <div class="py-8 text-center">
              <div class="text-4xl mb-4">&#127942;</div>
              <h2 class="text-lg font-semibold text-text-primary mb-2">Sessão finalizada</h2>
              <p class="text-text-secondary text-sm max-w-md mx-auto">
                Esta sessão foi concluída. Confira suas conquistas na aba Conquistas.
              </p>
              <div class="flex items-center justify-center gap-6 mt-6">
                <div>
                  <p class="text-2xl font-bold text-text-primary">{bugsCount}</p>
                  <p class="text-xs text-text-muted">Bugs reportados</p>
                </div>
                <div>
                  <p class="text-2xl font-bold text-text-primary">{participantsCount}</p>
                  <p class="text-xs text-text-muted">Participantes</p>
                </div>
              </div>
            </div>
          </Card>

          {bugsList.length > 0 && (
            <Card>
              <h2 class="text-sm font-semibold text-text-primary mb-3">Bugs reportados ({bugsList.length})</h2>
              <div class="space-y-2">
                {bugsList.map(b => (
                  <a href={`/sessions/${session.id}/bugs/${b.id}`} class="flex items-center justify-between p-3 rounded-lg bg-surface-2 hover:bg-surface-3 transition-colors">
                    <div class="min-w-0 flex-1">
                      <p class="text-sm font-medium text-text-primary truncate">{b.title}</p>
                      <p class="text-xs text-text-muted mt-0.5">{b.reporterName}</p>
                    </div>
                    <div class="flex items-center gap-2 ml-3">
                      <Badge variant="bug-severity" value={b.severity}>{bugSeverityLabel(b.severity)}</Badge>
                      <Badge variant="bug-status" value={b.status}>{bugStatusLabel(b.status)}</Badge>
                    </div>
                  </a>
                ))}
              </div>
            </Card>
          )}
        </div>
      )}
    </div>
  ) : (
    <!-- ==================== FACILITATOR / ADMIN VIEW ==================== -->
    <div class="p-8">
      <!-- Header -->
      <div class="flex items-start justify-between mb-6">
        <div>
          <div class="flex items-center gap-3 mb-2">
            <a href="/sessions" class="text-text-muted hover:text-text-primary text-sm">&larr; Sessões</a>
          </div>
          <h1 class="text-2xl font-bold text-text-primary">{session.title}</h1>
          <div class="flex items-center gap-3 mt-2">
            <Badge variant="session-status" value={session.status}>{sessionStatusLabel(session.status)}</Badge>
            <span class="text-text-muted text-sm">Criado por {session.creatorName} em {formatDate(session.createdAt)}</span>
          </div>
          {session.description && <p class="text-text-secondary mt-3 max-w-2xl whitespace-pre-line">{session.description}</p>}
          {session.scheduledAt && <p class="text-text-muted text-sm mt-2">Agendada para {formatDateTime(session.scheduledAt)}</p>}
          {session.startedAt && <p class="text-text-muted text-sm">Iniciada em {formatDateTime(session.startedAt)}</p>}
          {session.endedAt && <p class="text-text-muted text-sm">Finalizada em {formatDateTime(session.endedAt)}</p>}
        </div>
        <div class="flex items-center gap-3">
          {(isClosed || isWrapupPhase) && (
            <a href={`/sessions/${session.id}/report`} class="inline-flex items-center px-4 py-2 bg-surface-2 border border-surface-3 hover:bg-surface-3 text-text-primary text-sm font-medium rounded-lg transition-colors">
              Relatório
            </a>
          )}
          <SessionStatusControl sessionId={session.id} currentStatus={session.status} client:load />
        </div>
      </div>

      <!-- Timer (during active phases) -->
      {isActiveSession && (
        <div class="mb-6">
          <SessionTimer
            status={session.status}
            startedAt={session.startedAt?.toISOString() ?? null}
            kickoffDuration={session.kickoffDuration ?? 15}
            executionDuration={session.executionDuration ?? 60}
            wrapupDuration={session.wrapupDuration ?? 15}
            client:load
          />
        </div>
      )}

      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <Card class="!p-4">
          <p class="text-text-muted text-xs font-medium">Participantes</p>
          <p class="text-2xl font-bold text-text-primary mt-1">{participantsCount}</p>
        </Card>
        <Card class="!p-4">
          <p class="text-text-muted text-xs font-medium">Bugs</p>
          <p class="text-2xl font-bold text-text-primary mt-1">{bugsCount}</p>
        </Card>
        <Card class="!p-4">
          <p class="text-text-muted text-xs font-medium">Scripts</p>
          <p class="text-2xl font-bold text-text-primary mt-1">{scriptsCount}</p>
        </Card>
        <Card class="!p-4">
          <p class="text-text-muted text-xs font-medium">Credenciais</p>
          <p class="text-2xl font-bold text-text-primary mt-1">{credentialsCount}</p>
        </Card>
      </div>

      <!-- Execution Layout -->
      {isExecutionPhase ? (
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
          <!-- Left: Test Execution (2 cols) -->
          <div class="lg:col-span-2">
            <Card>
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-text-primary">Execução de Testes</h2>
                <div class="flex items-center gap-2">
                  {hasNewTestingJourney && (
                    <a href={`/sessions/${session.id}/script-builder`} class="inline-flex items-center px-3 py-1.5 bg-surface-2 hover:bg-surface-3 text-text-secondary text-xs font-medium rounded-lg transition-colors">
                      Editar Roteiro
                    </a>
                  )}
                  <a href={`/sessions/${session.id}/bugs/new`} class="inline-flex items-center px-3 py-1.5 bg-primary-600 hover:bg-primary-700 text-white text-xs font-medium rounded-lg transition-colors">
                    Reportar Bug
                  </a>
                </div>
              </div>
              {hasNewTestingJourney ? (
                <SessionExecution sessionId={session.id} userId={user.id} sections={sectionsList} client:load />
              ) : scriptsWithSteps.length > 0 ? (
                <TestScriptExecution sessionId={session.id} scripts={scriptsWithSteps} client:load />
              ) : (
                <p class="text-text-muted text-sm py-4 text-center">Nenhum script de teste cadastrado.</p>
              )}
            </Card>

            {/* Coverage Matrix */}
            {hasNewTestingJourney && (
              <Card class="mt-6">
                <div class="flex items-center justify-between mb-4">
                  <h2 class="text-lg font-semibold text-text-primary">Matriz de Cobertura</h2>
                </div>
                <CoverageMatrix sessionId={session.id} autoRefresh={true} client:load />
              </Card>
            )}
          </div>

          <!-- Right: Live Bug Feed -->
          <Card>
            <LiveBugFeed sessionId={session.id} initialBugs={bugsList} client:load />
          </Card>
        </div>
      ) : isWrapupPhase ? (
        <!-- Wrapup: Triage Table -->
        <Card class="mb-8">
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-text-primary">Triagem de Bugs</h2>
            <span class="text-xs text-text-muted">{bugsList.length} bug(s)</span>
          </div>
          {bugsList.length === 0 ? (
            <p class="text-text-muted text-sm py-4 text-center">Nenhum bug para triagem.</p>
          ) : (
            <TriageTable sessionId={session.id} bugs={bugsList} client:load />
          )}
        </Card>
      ) : null}

      <div class="space-y-8">
        <!-- Participants Section -->
        <Card>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-text-primary">Participantes</h2>
            <AddParticipant sessionId={session.id} client:load />
          </div>
          {participantsList.length === 0 ? (
            <p class="text-text-muted text-sm py-4 text-center">Nenhum participante adicionado.</p>
          ) : (
            <div class="space-y-2">
              {participantsList.map(p => (
                <div class="flex items-center justify-between p-3 rounded-lg bg-surface-2">
                  <div>
                    <p class="text-sm font-medium text-text-primary">{p.name}</p>
                    <p class="text-xs text-text-muted">{p.email}</p>
                  </div>
                  <form method="POST" action={`/api/sessions/${session.id}/participants`}>
                    <input type="hidden" name="_method" value="DELETE" />
                    <input type="hidden" name="userId" value={p.userId} />
                    <button type="submit" class="text-xs text-text-muted hover:text-severity-blocker transition-colors">Remover</button>
                  </form>
                </div>
              ))}
            </div>
          )}
        </Card>

        <!-- Test Scripts (non-execution phases) -->
        {!isExecutionPhase && (
          <Card>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-text-primary">Scripts de Teste</h2>
              <div class="flex items-center gap-3">
                {hasNewTestingJourney && (
                  <a href={`/sessions/${session.id}/script-builder`} class="text-sm text-primary-400 hover:text-primary-300">Gerenciar Roteiro</a>
                )}
                <a href={`/sessions/${session.id}/scripts/new`} class="text-sm text-primary-400 hover:text-primary-300">Novo Script</a>
              </div>
            </div>
            {isActiveSession && !isExecutionPhase && scriptsWithSteps.length > 0 ? (
              <TestScriptExecution sessionId={session.id} scripts={scriptsWithSteps} client:load />
            ) : scriptsWithSteps.length === 0 ? (
              <p class="text-text-muted text-sm py-4 text-center">Nenhum script de teste cadastrado.</p>
            ) : (
              <div class="space-y-3">
                {scriptsWithSteps.map(s => (
                  <div class="p-4 rounded-lg bg-surface-2">
                    <div class="flex items-center justify-between">
                      <p class="text-sm font-medium text-text-primary">{s.title}</p>
                      {s.steps.length > 0 && <span class="text-xs text-text-muted">{s.steps.length} passo(s)</span>}
                    </div>
                    {s.description && <p class="text-xs text-text-secondary mt-1 whitespace-pre-line">{s.description}</p>}
                    {s.steps.length > 0 && (
                      <div class="mt-3 space-y-1">
                        {s.steps.map((step, idx) => (
                          <div class="flex items-start gap-2 text-xs text-text-secondary">
                            <span class="text-text-muted w-4 text-right flex-shrink-0">{idx + 1}.</span>
                            <span class="whitespace-pre-line">{step.instruction}</span>
                            {step.expectedResult && <span class="text-text-muted ml-1 whitespace-pre-line">— {step.expectedResult}</span>}
                          </div>
                        ))}
                      </div>
                    )}
                  </div>
                ))}
              </div>
            )}
          </Card>
        )}

        <!-- Credentials Section -->
        <Card>
          <div class="flex items-center justify-between mb-4">
            <h2 class="text-lg font-semibold text-text-primary">Credenciais de Teste</h2>
          </div>
          <form method="POST" action={`/api/sessions/${session.id}/credentials`} class="flex items-end gap-3 mb-4">
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Perfil</label>
              <input type="text" name="profileType" required placeholder="Ex: Admin" class="w-full px-2 py-1.5 bg-surface-2 border border-surface-3 rounded text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-1 focus:ring-primary-500" />
            </div>
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Usuário</label>
              <input type="text" name="username" required placeholder="user@test.com" class="w-full px-2 py-1.5 bg-surface-2 border border-surface-3 rounded text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-1 focus:ring-primary-500" />
            </div>
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Senha</label>
              <input type="text" name="password" required placeholder="••••" class="w-full px-2 py-1.5 bg-surface-2 border border-surface-3 rounded text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-1 focus:ring-primary-500" />
            </div>
            <div class="flex-1">
              <label class="block text-xs text-text-muted mb-1">Ambiente</label>
              <input type="text" name="environment" placeholder="staging" class="w-full px-2 py-1.5 bg-surface-2 border border-surface-3 rounded text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:ring-1 focus:ring-primary-500" />
            </div>
            <button type="submit" class="px-3 py-1.5 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded transition-colors">Adicionar</button>
          </form>
          {credentialsList.length === 0 ? (
            <p class="text-text-muted text-sm py-4 text-center">Nenhuma credencial cadastrada.</p>
          ) : (
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr class="border-b border-surface-3">
                    <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Perfil</th>
                    <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Usuário</th>
                    <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Senha</th>
                    <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Ambiente</th>
                    <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Reservado por</th>
                    <th class="px-3 py-2"></th>
                  </tr>
                </thead>
                <tbody>
                  {credentialsList.map(c => (
                    <tr class="border-b border-surface-3 last:border-0">
                      <td class="px-3 py-2 text-text-primary">{c.profileType}</td>
                      <td class="px-3 py-2 text-text-secondary">{c.username}</td>
                      <td class="px-3 py-2 text-text-secondary font-mono">{c.password}</td>
                      <td class="px-3 py-2 text-text-secondary">{c.environment || '—'}</td>
                      <td class="px-3 py-2 text-text-secondary">{c.claimedByName || '—'}</td>
                      <td class="px-3 py-2 text-right">
                        {c.claimedBy === user.id ? (
                          <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                            <input type="hidden" name="_method" value="DELETE" />
                            <button type="submit" class="text-xs text-severity-major hover:text-severity-blocker">Liberar</button>
                          </form>
                        ) : !c.claimedBy ? (
                          <form method="POST" action={`/api/sessions/${session.id}/credentials/${c.id}/claim`} class="inline">
                            <button type="submit" class="text-xs text-primary-400 hover:text-primary-300">Reservar</button>
                          </form>
                        ) : null}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </Card>

        <!-- Bugs Section (non-execution, non-wrapup phases) -->
        {!isExecutionPhase && !isWrapupPhase && (
          <Card>
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold text-text-primary">Bugs</h2>
              <a href={`/sessions/${session.id}/bugs/new`} class="text-sm text-primary-400 hover:text-primary-300">Reportar Bug</a>
            </div>
            {bugsList.length === 0 ? (
              <p class="text-text-muted text-sm py-4 text-center">Nenhum bug reportado nesta sessão.</p>
            ) : (
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-surface-3">
                      <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Título</th>
                      <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Severidade</th>
                      <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Status</th>
                      <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Reportado por</th>
                      <th class="text-left px-3 py-2 text-text-muted font-medium text-xs">Data</th>
                    </tr>
                  </thead>
                  <tbody>
                    {bugsList.map(b => (
                      <tr class="border-b border-surface-3 last:border-0 hover:bg-surface-2 transition-colors">
                        <td class="px-3 py-2">
                          <a href={`/sessions/${session.id}/bugs/${b.id}`} class="text-text-primary hover:text-primary-400 font-medium">{b.title}</a>
                        </td>
                        <td class="px-3 py-2"><Badge variant="bug-severity" value={b.severity}>{bugSeverityLabel(b.severity)}</Badge></td>
                        <td class="px-3 py-2"><Badge variant="bug-status" value={b.status}>{bugStatusLabel(b.status)}</Badge></td>
                        <td class="px-3 py-2 text-text-secondary">{b.reporterName}</td>
                        <td class="px-3 py-2 text-text-secondary">{formatDate(b.createdAt)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </Card>
        )}
      </div>
    </div>
  )}

  {/* Badge notifications during active sessions */}
  {(session.status === 'execution' || session.status === 'kickoff') && (
    <BadgeToast sessionId={id!} userId={user.id} client:load />
  )}
</AppLayout>
